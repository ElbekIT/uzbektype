{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Represents the user's setup profile",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Unique Firebase User ID"
        },
        "firstName": {
          "type": "string",
          "maxLength": 50,
          "description": "First name of the user"
        },
        "lastName": {
          "type": "string",
          "maxLength": 50,
          "description": "Last name of the user"
        },
        "avatar": {
          "type": "string",
          "description": "ID of selected pixel avatar"
        },
        "email": {
          "type": "string",
          "description": "User's Google Account email address"
        },
        "createdAt": {
          "type": "object",
          "description": "Firestore server timestamp"
        }
      },
      "required": ["uid", "firstName", "lastName", "avatar", "email"]
    },
    "TypingResult": {
      "title": "TypingResult",
      "description": "Represents the stats of a completed typing test",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "User ID of the player"
        },
        "wpm": {
          "type": "number",
          "description": "Words per Minute (Net speed)"
        },
        "accuracy": {
          "type": "number",
          "description": "Accuracy percentage"
        },
        "raw": {
          "type": "number",
          "description": "Raw WPM speed without penalty"
        },
        "consistency": {
          "type": "number",
          "description": "Typing consistency percentage"
        },
        "difficulty": {
          "type": "string",
          "enum": ["oson", "o'rta", "qiyin"],
          "description": "Difficulty setting"
        },
        "time": {
          "type": "number",
          "description": "Test duration selected (10, 30, 60)"
        },
        "createdAt": {
          "type": "object",
          "description": "Firestore server timestamp of when test was completed"
        }
      },
      "required": ["uid", "wpm", "accuracy", "raw", "consistency", "difficulty", "time"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Stores individual user profile configuration and chosen pixel avatars"
    },
    "/results/{resultId}": {
      "schema": "TypingResult",
      "description": "Stores user typing speed results"
    },
    "/leaderboard/{leaderboardId}": {
      "schema": "TypingResult",
      "description": "Caches top scores for the real-time leaderboard ranking"
    }
  }
}
